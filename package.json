{
	"name": "slowbreath",
	"description": "A simple, free, full-screen slow-breathing pacer. Box breathing (4-4-4-4) and other research-backed protocols. Designed for blood pressure, anxiety, and focus.",
	"private": true,
	"version": "1.0.3",
	"license": "AGPL-3.0-or-later",
	"homepage": "https://slowbreath.app",
	"keywords": [
		"box-breathing",
		"slow-breathing",
		"breathing-exercise",
		"anxiety",
		"blood-pressure",
		"sveltekit",
		"cloudflare-workers"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "wrangler types --check && npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "2.20.0",
		"@playwright/test": "1.61.0",
		"@sveltejs/adapter-cloudflare": "7.2.9",
		"@sveltejs/kit": "2.66.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.1",
		"@types/node": "25.9.3",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "5.56.3",
		"svelte-check": "4.6.0",
		"tailwindcss": "4.3.1",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"wrangler": "4.102.0"
	}
}
